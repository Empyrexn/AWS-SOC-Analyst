<!-- Wazuh MANAGER: forward alerts to TheHive via the custom integration.
     Place INSIDE <ossec_config> in /var/ossec/etc/ossec.conf on the manager.
     Outside <ossec_config> you'll get "Invalid element" and the manager won't start.
     hook_url is TheHive on :9000 (host-published app port).
     Replace the IP with your TheHive host and the key with your TheHive SERVICE-USER key
     (a TheHive key, NOT the Cortex key). See docs/07-wazuh-thehive-integration.md -->
<integration>
  <name>custom-w2thive</name>
  <hook_url>http://10.0.10.29:9000</hook_url>
  <api_key>REPLACE_WITH_THEHIVE_SERVICE_USER_API_KEY</api_key>
  <alert_format>json</alert_format>
</integration>
